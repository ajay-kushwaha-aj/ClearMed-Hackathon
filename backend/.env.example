# ── Email (SMTP / Resend) ────────────────────────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="resend"
SMTP_PASS="re_your_api_key"
SMTP_FROM="ClearMed <noreply@clearmed.in>"

# ── SMS (MSG91) ───────────────────────────────────────────────────────────
MSG91_API_KEY=""
MSG91_SENDER_ID="CLRMED"

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL="info"

# ── Score settings ────────────────────────────────────────────────────────
MIN_BILLS_FOR_RELIABLE_SCORE=5
