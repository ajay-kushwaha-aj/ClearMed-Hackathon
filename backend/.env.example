# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.tmhlgpkwnwdaesdyfiqx.supabase.co:5432/postgres?sslmode=require"

# ── App ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ── Auth & Security ───────────────────────────────────────────────────────
JWT_SECRET="change_this_to_64_char_random_string_in_production"
