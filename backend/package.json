    "@types/nodemailer": "^6.4.15",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.5",
    "prisma": "^5.15.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
